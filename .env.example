# G-Track Backend Environment Configuration
# Copy this file to .env and update with your actual values

# ==========================================
# Database Configuration
# ==========================================
# Format: postgresql+asyncpg://username:password@host:port/database
# Local example: postgresql+asyncpg://gtrack_user:password123@localhost:5432/gtrack_db
# Heroku: DATABASE_URL is automatically set
# AWS RDS: postgresql+asyncpg://user:pass@your-db.xxxxx.rds.amazonaws.com:5432/gtrack_db
SQLALCHEMY_DATABASE_URL=postgresql+asyncpg://gtrack_user:your_password@localhost:5432/gtrack_db

# ==========================================
# API Configuration
# ==========================================
API_VERSION=1.0
DEBUG=True
ENVIRONMENT=development

# ==========================================
# Security Configuration
# ==========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MUST be changed for production
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# CORS Configuration
# ==========================================
# Comma-separated list or JSON array of allowed origins
# Development: http://localhost:5173,http://localhost:3000
# Production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173","http://127.0.0.1:3000"]

# ==========================================
# Email/SMTP Configuration
# ==========================================
# For sending notifications, password resets, welcome emails, etc.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password
SENDER_NAME=G-Track System

# ==========================================
# Machine Learning Models
# ==========================================
# Path to ML models directory
MODEL_PATH=./models/

# ==========================================
# Optional: Monitoring & Logging
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==========================================
# Optional: Rate Limiting
# ==========================================
RATE_LIMIT_CALLS=100
RATE_LIMIT_PERIOD=60

# ==========================================
# Optional: File Upload
# ==========================================
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
UPLOAD_DIRECTORY=./uploads
